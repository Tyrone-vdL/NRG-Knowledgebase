# Editor noise
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Local-only drafts that aren't ready to ship
drafts/
*.draft.md

# Secrets — never commit
*.env
.env.*
.env
# ...but keep the template (no secrets in it)
!.env.example

# Bot runtime / dependencies
node_modules/
logs/
*.bak
*.tar.gz

# Bot Q&A logs — raw dailies stay local (large/noisy); only the distilled,
# machine-mined learning artifacts are tracked so droplet→repo telemetry works.
bot-logs/*
!bot-logs/feedback.jsonl
!bot-logs/coverage-gaps-queue.md
