{
  "name": "nrg-discord-bot",
  "version": "3.0.0",
  "description": "NRG Knowledge Base Discord bot — wiki Q&A (retrieval architecture) + self-serve ingestion",
  "type": "module",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "dev": "node --watch bot.js",
    "dry-run": "node bot.js --dry-run",
    "sync-wiki": "node tools/sync-wiki.mjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop nrg-bot",
    "pm2:logs": "pm2 logs nrg-bot",
    "pm2:status": "pm2 status nrg-bot"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1"
  }
}
