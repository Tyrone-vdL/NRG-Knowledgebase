# NRG Discord Bot — environment variables
# Copy this file to `.env` and fill in EVERY value.
# Never commit `.env` to git (see .gitignore).
# =============================================================================

# Discord bot token (from https://discord.com/developers/applications → Bot → Reset Token)
DISCORD_TOKEN=

# Discord application client ID (from the Application's "General Information" page)
DISCORD_CLIENT_ID=

# Discord server (guild) ID
# Enable Developer Mode in Discord (User Settings → Advanced → Developer Mode),
# then right-click the server icon → "Copy Server ID"
DISCORD_GUILD_ID=

# Channel ID for #wiki-bot — every message here becomes a wiki query
# Right-click channel → Copy Channel ID
WIKI_BOT_CHANNEL_ID=

# Channel ID for #ingest — file uploads here trigger the ingestion flow
INGEST_CHANNEL_ID=

# Discord user ID of the bot owner (Choppa) — only this user can approve ingests
# Right-click your own username in the member list → Copy User ID
OWNER_USER_ID=

# Optional: role ID required to query the bot. Leave empty for "any guild member".
# When set, only users with this role can talk to the bot (recommended once team is onboarded).
# Right-click the role in Server Settings → Roles → Copy Role ID
NRG_TEAM_ROLE_ID=

# Anthropic API key (from https://console.anthropic.com → Settings → API Keys)
ANTHROPIC_API_KEY=

# Absolute path to the wiki folder ON THE DROPLET
# Recommended: /opt/nrg-bot/wiki
WIKI_ROOT=/opt/nrg-bot/wiki

# Anthropic model. claude-sonnet-4-6 is the recommended balance of speed/quality.
# Alternatives: claude-opus-4-6 (slower, more accurate), claude-haiku-4-5-20251001 (faster, cheaper)
MODEL=claude-sonnet-4-6

# Max file size for ingestion uploads (bytes). Default 20 MB.
MAX_INGEST_BYTES=20971520

# Max retrieval tool rounds per query before the bot is forced to answer
# with whatever it has fetched. Default 3.
MAX_TOOL_ROUNDS=3

# Per-query retrieval budget in characters across all fetched wiki pages.
# Keeps a greedy fetch from blowing out token cost. Default 120000 (~30K tokens).
MAX_FETCH_CHARS=120000
